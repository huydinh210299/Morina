<% if (success) { %>
  <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800 shadow-sm">
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-800 shadow-sm">
    <%= error %>
  </div>
<% } %>
