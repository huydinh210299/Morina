        <a href="/users" class="rounded-full px-4 py-2 text-slate-700 transition hover:bg-brand-50 hover:text-brand-700">Quản lý</a>
      <% } %>
      <span class="rounded-full bg-slate-900 px-4 py-2 text-white"><%= currentUser.username %> | <%= currentUser.role %></span>
