        <a href="/finance" class="rounded-full px-4 py-2 text-slate-700 transition hover:bg-brand-50 hover:text-brand-700">Tài chính</a>
      <% } %>
      <% if (currentUser.role === "staff") { %>
        <a href="/users/timekeeping" class="rounded-full px-4 py-2 text-slate-700 transition hover:bg-brand-50 hover:text-brand-700">Chấm công</a>
      <% } %>
