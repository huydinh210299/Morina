<section class="mx-auto max-w-3xl space-y-6">
  <%- include("../../partials/product-management-tabs", { activeProductManagementTab: "accessories" }) %>

  <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
    <h1 class="text-3xl font-black text-slate-900"><%= title %></h1>

    <form action="<%= formAction %>" method="<%= formMethod %>" class="mt-8 grid gap-5 md:grid-cols-2">
      <div>
        <label class="mb-2 block text-sm font-semibold text-slate-700">Mã</label>
        <input name="code" type="text" required value="<%= accessory?.code || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
      </div>

      <div>
        <label class="mb-2 block text-sm font-semibold text-slate-700">Tên</label>
        <input name="name" type="text" required value="<%= accessory?.name || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
      </div>

      <div class="md:col-span-2">
        <label class="mb-2 block text-sm font-semibold text-slate-700">Giá</label>
        <input name="price" type="number" min="0" step="0.01" required value="<%= accessory?.price ?? '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
      </div>

      <div class="md:col-span-2">
        <label class="mb-2 block text-sm font-semibold text-slate-700">Số lượng</label>
        <input name="amount" type="number" min="0" step="1" required value="<%= accessory?.amount ?? 0 %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
      </div>

      <div class="md:col-span-2">
        <label class="mb-2 block text-sm font-semibold text-slate-700">URL hình ảnh</label>
        <input name="imageUrl" type="url" value="<%= accessory?.imageUrl || '' %>" placeholder="Nhập liên kết hình ảnh phụ kiện" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
      </div>

      <div class="md:col-span-2">
        <label class="mb-2 block text-sm font-semibold text-slate-700">Ghi chú</label>
        <textarea name="note" rows="4" placeholder="Nhập ghi chú cho phụ kiện" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"><%= accessory?.note || '' %></textarea>
      </div>

      <div class="md:col-span-2 flex gap-3">
        <button type="submit" class="rounded-full bg-brand-500 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Lưu phụ kiện</button>
        <a href="/accessories" class="rounded-full bg-slate-100 px-6 py-3 font-semibold text-slate-700">Hủy</a>
      </div>
    </form>
  </div>
</section>
