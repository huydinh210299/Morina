<section class="min-w-0 space-y-6">
  <%- include("../../partials/product-management-tabs", { activeProductManagementTab: "accessories" }) %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-black text-slate-900">Phụ kiện</h1>
      <p class="mt-1 text-slate-500">Quản lý phụ kiện đi kèm và giá cho thuê của chúng.</p>
    </div>
    <% if (currentUser.role === "admin") { %>
      <a href="/accessories/new" class="inline-flex rounded-full bg-brand-500 px-5 py-3 font-semibold text-white transition hover:bg-brand-700">Thêm phụ kiện</a>
    <% } %>
  </div>

  <div class="min-w-0 overflow-hidden rounded-3xl bg-white shadow-lg shadow-slate-200/60">
    <div class="table-scroll">
      <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Hình ảnh</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Mã</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Tên</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Ghi chú</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Giá</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Số lượng</th>
          <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Thao tác</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% accessories.forEach((accessory) => { %>
          <tr>
            <td class="px-6 py-4">
              <% if (accessory.imageUrl) { %>
                <button
                  type="button"
                  class="block rounded-2xl transition hover:-translate-y-0.5 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-brand-100"
                  data-accessory-image-preview
                  data-accessory-code="<%= accessory.code %>"
                  data-accessory-name="<%= accessory.name %>"
                  data-accessory-image-url="<%= accessory.imageUrl %>"
                  data-accessory-detail-url="/accessories/<%= accessory._id %>"
                  aria-label="Xem ảnh lớn của phụ kiện <%= accessory.name %>"
                >
                  <img src="<%= accessory.imageUrl %>" alt="Hình ảnh phụ kiện <%= accessory.name %>" class="h-28 w-28 rounded-2xl object-cover ring-1 ring-slate-200" loading="lazy" referrerpolicy="no-referrer" />
                </button>
              <% } else { %>
                <div class="flex h-28 w-28 items-center justify-center rounded-2xl bg-slate-100 px-3 text-center text-xs font-semibold text-slate-500">Chưa có ảnh</div>
              <% } %>
            </td>
            <td class="px-6 py-4 font-semibold text-slate-900">
              <a href="/accessories/<%= accessory._id %>" class="transition hover:text-brand-700"><%= accessory.code %></a>
            </td>
            <td class="px-6 py-4 text-slate-600">
              <a href="/accessories/<%= accessory._id %>" class="transition hover:text-brand-700"><%= accessory.name %></a>
            </td>
            <td class="max-w-xs px-6 py-4 text-slate-600"><%= accessory.note || "-" %></td>
            <td class="px-6 py-4 text-slate-600"><%= formatCurrency(accessory.price) %></td>
            <td class="px-6 py-4 text-slate-600"><%= accessory.amount ?? 0 %></td>
            <td class="px-6 py-4">
              <div class="flex justify-end gap-2">
                <a href="/accessories/<%= accessory._id %>/rentals" class="rounded-full bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700">Lịch thuê</a>
                <% if (currentUser.role === "admin") { %>
                  <a href="/accessories/<%= accessory._id %>/edit" class="rounded-full bg-amber-100 px-4 py-2 text-sm font-semibold text-amber-800">Sửa</a>
                  <form action="/accessories/<%= accessory._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Xóa phụ kiện này?');">
                    <button type="submit" class="rounded-full bg-rose-100 px-4 py-2 text-sm font-semibold text-rose-800">Xóa</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
      </table>
    </div>
  </div>

  <div class="flex flex-col gap-3 rounded-3xl bg-white px-6 py-4 text-sm text-slate-600 shadow-lg shadow-slate-200/60 sm:flex-row sm:items-center sm:justify-between">
    <span>Trang <%= pagination.page %>/<%= pagination.totalPages %> · Tổng <%= pagination.totalItems %> phụ kiện</span>
    <div class="flex gap-2">
      <% if (pagination.hasPrev) { %>
        <a href="/accessories?page=<%= pagination.prevPage %>" class="rounded-full bg-slate-100 px-4 py-2 font-semibold text-slate-700">Trang trước</a>
      <% } %>
      <% if (pagination.hasNext) { %>
        <a href="/accessories?page=<%= pagination.nextPage %>" class="rounded-full bg-brand-50 px-4 py-2 font-semibold text-brand-700">Trang sau</a>
      <% } %>
    </div>
  </div>

  <div
    class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/75 p-4"
    data-accessory-image-modal
    aria-hidden="true"
  >
    <div class="relative flex max-h-[92vh] w-full max-w-5xl flex-col overflow-hidden rounded-3xl bg-white shadow-2xl">
      <div class="flex items-center justify-between gap-4 border-b border-slate-100 px-5 py-4">
        <div class="min-w-0">
          <h2 class="truncate text-xl font-black text-slate-900" data-accessory-image-modal-title></h2>
          <p class="mt-1 truncate text-sm text-slate-500">Ảnh phụ kiện</p>
        </div>
        <button
          type="button"
          class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-100 text-2xl font-semibold leading-none text-slate-600 transition hover:bg-slate-200"
          data-accessory-image-modal-close
          aria-label="Đóng bản xem trước"
        >
          &times;
        </button>
      </div>

      <div class="flex min-h-0 flex-1 items-center justify-center bg-slate-100 p-4">
        <img
          src=""
          alt=""
          class="max-h-[70vh] w-auto max-w-full rounded-2xl object-contain shadow-lg shadow-slate-300/40"
          data-accessory-image-modal-img
          referrerpolicy="no-referrer"
        />
      </div>

      <div class="flex justify-end gap-3 border-t border-slate-100 px-5 py-4">
        <button
          type="button"
          class="inline-flex rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700 transition hover:bg-slate-200"
          data-accessory-image-modal-close
        >
          Đóng
        </button>
        <a
          href="#"
          class="inline-flex rounded-full bg-slate-900 px-5 py-3 font-semibold text-white transition hover:bg-slate-700"
          data-accessory-image-modal-detail
        >
          Xem chi tiết phụ kiện
        </a>
      </div>
    </div>
  </div>
</section>
