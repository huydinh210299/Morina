<section class="mx-auto max-w-6xl space-y-6">
  <%- include("../../partials/product-management-tabs", { activeProductManagementTab: "accessories" }) %>

  <div class="flex flex-col gap-4 rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-brand-700">Lịch thuê phụ kiện</p>
      <h1 class="mt-2 text-3xl font-black text-slate-900"><%= accessory.code %> - <%= accessory.name %></h1>
      <p class="mt-3 text-slate-600">Tổng số lượng: <span class="font-semibold"><%= accessory.amount ?? 0 %></span></p>
    </div>
    <a href="/accessories" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700">Quay lại</a>
  </div>

  <div class="overflow-hidden rounded-3xl bg-white shadow-lg shadow-slate-200/60">
    <div class="table-scroll">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Ngày thuê</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Số lượng thuê</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Số lượng còn lại</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Khách hàng</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% if (rentalDays.length === 0) { %>
            <tr>
              <td colspan="4" class="px-6 py-10 text-center text-slate-500">Chưa có lịch thuê từ hôm nay cho phụ kiện này.</td>
            </tr>
          <% } %>
          <% rentalDays.forEach((day) => { %>
            <tr>
              <td class="px-6 py-4 font-semibold text-slate-900"><%= new Date(`${day.date}T00:00:00`).toLocaleDateString("vi-VN") %></td>
              <td class="px-6 py-4 text-slate-600"><%= day.amount %></td>
              <td class="px-6 py-4 text-slate-600"><%= day.availableAmount %></td>
              <td class="px-6 py-4 text-slate-600">
                <div class="space-y-1">
                  <% day.rentals.forEach((rental) => { %>
                    <p>
                      <%= rental.customerName %> (<%= rental.phone %>) · <%= rental.amount %> · <%= rental.returned ? "Đã trả" : "Đang thuê" %>
                      <a href="/orders/<%= rental.orderId %>" class="ml-1 font-semibold text-brand-700 hover:text-brand-800">Xem đơn hàng</a>
                    </p>
                  <% }) %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="flex flex-col gap-3 rounded-3xl bg-white px-6 py-4 text-sm text-slate-600 shadow-lg shadow-slate-200/60 sm:flex-row sm:items-center sm:justify-between">
    <span>Trang <%= pagination.page %>/<%= pagination.totalPages %> · Tổng <%= pagination.totalItems %> ngày thuê</span>
    <div class="flex gap-2">
      <% if (pagination.hasPrev) { %>
        <a href="/accessories/<%= accessory._id %>/rentals?page=<%= pagination.prevPage %>" class="rounded-full bg-slate-100 px-4 py-2 font-semibold text-slate-700">Trang trước</a>
      <% } %>
      <% if (pagination.hasNext) { %>
        <a href="/accessories/<%= accessory._id %>/rentals?page=<%= pagination.nextPage %>" class="rounded-full bg-brand-50 px-4 py-2 font-semibold text-brand-700">Trang sau</a>
      <% } %>
    </div>
  </div>
</section>
