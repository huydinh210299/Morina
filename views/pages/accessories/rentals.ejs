<section class="mx-auto max-w-6xl space-y-6">
  <%- include("../../partials/product-management-tabs", { activeProductManagementTab: "accessories" }) %>

  <div class="flex flex-col gap-4 rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-brand-700">Lịch thuê phụ kiện</p>
      <h1 class="mt-2 text-3xl font-black text-slate-900"><%= accessory.code %> - <%= accessory.name %></h1>
      <p class="mt-3 text-slate-600">Tổng số lượng: <span class="font-semibold"><%= accessory.amount ?? 0 %></span></p>
    </div>
    <a href="/accessories" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700">Quay lại</a>
  </div>

  <div class="rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60">
    <div>
      <h2 class="text-2xl font-black text-slate-900">Tất cả đơn thuê</h2>
      <p class="mt-1 text-slate-500">Xem từng đơn và khung thời gian thuê để quyết định tình trạng phụ kiện.</p>
    </div>

    <% if (rentals.length === 0) { %>
      <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center text-slate-500">
        Chưa có đơn thuê nào cho phụ kiện này.
      </div>
    <% } else { %>
      <div class="mt-6 space-y-4">
        <% rentals.forEach((rental) => { %>
          <article class="rounded-3xl border border-slate-200 p-5">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-3">
                  <a href="/orders/<%= rental.orderId %>" class="text-lg font-bold text-slate-900 transition hover:text-brand-700">Xem đơn hàng</a>
                </div>
                <p class="mt-2 text-slate-600"><%= rental.customerName %> · <%= rental.phone %></p>
              </div>
              <p class="rounded-2xl bg-brand-50 px-4 py-3 text-sm font-semibold text-brand-800">Số lượng: <%= rental.amount %></p>
            </div>

            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Bắt đầu</p>
                <p class="mt-2 font-semibold text-slate-900"><%= formatDateTime(rental.startTime) %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Kết thúc</p>
                <p class="mt-2 font-semibold text-slate-900"><%= formatDateTime(rental.endTime) %></p>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="flex flex-col gap-3 rounded-3xl bg-white px-6 py-4 text-sm text-slate-600 shadow-lg shadow-slate-200/60 sm:flex-row sm:items-center sm:justify-between">
    <span>Trang <%= pagination.page %>/<%= pagination.totalPages %> · Tổng <%= pagination.totalItems %> đơn thuê</span>
    <div class="flex gap-2">
      <% if (pagination.hasPrev) { %>
        <a href="/accessories/<%= accessory._id %>/rentals?page=<%= pagination.prevPage %>" class="rounded-full bg-slate-100 px-4 py-2 font-semibold text-slate-700">Trang trước</a>
      <% } %>
      <% if (pagination.hasNext) { %>
        <a href="/accessories/<%= accessory._id %>/rentals?page=<%= pagination.nextPage %>" class="rounded-full bg-brand-50 px-4 py-2 font-semibold text-brand-700">Trang sau</a>
      <% } %>
    </div>
  </div>
</section>
