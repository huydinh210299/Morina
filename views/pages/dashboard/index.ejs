<section class="space-y-8">
  <div class="rounded-[2rem] bg-slate-900 p-8 text-white shadow-2xl shadow-slate-300">
    <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-100">Tổng quan</p>
    <div class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h1 class="text-4xl font-black">Xin chào, <%= currentUser.username %></h1>
        <p class="mt-3 max-w-2xl text-slate-300">Theo dõi nhanh các đơn cần xử lý trong ngày.</p>
      </div>
      <a href="/orders/new" class="inline-flex rounded-full bg-white px-6 py-3 font-semibold text-slate-900 transition hover:bg-brand-50">Tạo đơn hàng mới</a>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
    <a href="/orders?todayOrders=on" class="group rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-300/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Đơn hôm nay</p>
      <p class="mt-4 text-4xl font-black text-slate-900"><%= stats.todayOrders %></p>
      <p class="mt-3 text-sm text-slate-500 transition group-hover:text-brand-700">Xem danh sách đơn bắt đầu hôm nay</p>
    </a>
    <a href="/orders?tomorrowOrders=on" class="group rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-300/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Đơn ngày mai</p>
      <p class="mt-4 text-4xl font-black text-slate-900"><%= stats.tomorrowOrders %></p>
      <p class="mt-3 text-sm text-slate-500 transition group-hover:text-brand-700">Xem danh sách đơn bắt đầu ngày mai</p>
    </a>
    <a href="/orders?todayOrders=on&tomorrowOrders=on&important=on&excludeCompletedImportant=on" class="group rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-300/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Đơn quan trọng</p>
      <p class="mt-4 text-4xl font-black text-slate-900"><%= stats.importantOrders %></p>
      <p class="mt-3 text-sm text-slate-500 transition group-hover:text-brand-700">Xem các đơn được đánh dấu quan trọng</p>
    </a>
    <a href="/orders?todayOrders=on&tomorrowOrders=on&bookship=true&pickup=false" class="group rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-300/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Đơn giao hàng</p>
      <p class="mt-4 text-4xl font-black text-slate-900"><%= stats.bookshipOrders %></p>
      <p class="mt-3 text-sm text-slate-500 transition group-hover:text-brand-700">Xem các đơn có yêu cầu giao hàng</p>
    </a>
  </div>
</section>
