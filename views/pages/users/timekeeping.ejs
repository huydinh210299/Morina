<section class="space-y-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-3xl font-black text-slate-900">Cham cong</h1>
      <p class="mt-1 text-slate-500">Tao cham cong theo ca lam va gui yeu cau hoa hong de admin duyet.</p>
    </div>
    <form method="GET" action="/users/timekeeping" class="flex items-center gap-3">
      <input name="month" type="month" value="<%= selectedMonth %>" class="rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
      <button type="submit" class="rounded-full bg-slate-900 px-5 py-3 font-semibold text-white transition hover:bg-slate-700">Xem thang</button>
    </form>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr_1.3fr]">
    <form action="/users/timekeeping" method="POST" class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
      <h2 class="text-2xl font-black text-slate-900">Tao cham cong moi</h2>
      <% if (shifts.length === 0) { %>
        <p class="mt-4 text-slate-500">Chua co ca lam nao. Hay nho admin tao ca lam truoc.</p>
      <% } else { %>
        <div class="mt-6 space-y-5">
          <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700">Ca lam</label>
            <select name="shiftId" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100">
              <option value="">Chon ca lam</option>
              <% shifts.forEach((shift) => { %>
                <option value="<%= shift._id %>"><%= shift.name %> - <%= shift.hour %> gio</option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700">Ngay lam</label>
            <input name="date" type="date" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
          </div>
          <button type="submit" class="rounded-full bg-brand-500 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Luu cham cong</button>
        </div>
      <% } %>
    </form>

    <form action="/users/commissions" method="POST" class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
      <h2 class="text-2xl font-black text-slate-900">Gui yeu cau hoa hong</h2>
      <input type="hidden" name="month" value="<%= selectedMonth %>" />
      <div class="mt-6 space-y-5">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Ngay</label>
          <input name="date" type="date" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">So tien hoa hong</label>
          <input name="amount" type="number" min="0" step="1" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Mo ta</label>
          <textarea name="description" rows="3" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" placeholder="Vi du: thuong upsell, ho tro khach VIP..."></textarea>
        </div>
        <button type="submit" class="rounded-full bg-emerald-600 px-6 py-3 font-semibold text-white transition hover:bg-emerald-700">Gui yeu cau</button>
      </div>
    </form>

    <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
      <h2 class="text-2xl font-black text-slate-900">Lich su thang <%= selectedMonth %></h2>
      <div class="mt-6 space-y-4">
        <% if (entries.length === 0 && commissionEntries.length === 0) { %>
          <p class="text-slate-500">Chua co cham cong hay yeu cau hoa hong trong thang nay.</p>
        <% } %>

        <% entries.forEach((entry) => { %>
          <div class="rounded-3xl border border-slate-200 p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="font-semibold text-slate-900"><%= entry.shiftName %> - <%= entry.hour %> gio</p>
                <p class="mt-1 text-sm text-slate-500"><%= formatDateTime(entry.date) %></p>
                <p class="mt-1 text-sm text-slate-500"><%= entry.shiftDescription || "Khong co mo ta" %></p>
              </div>
              <span class="rounded-full px-4 py-2 text-sm font-semibold <%= entry.approved ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' %>">
                <%= entry.approved ? "Da duyet" : "Cho duyet" %>
              </span>
            </div>
          </div>
        <% }) %>

        <% commissionEntries.forEach((entry) => { %>
          <div class="rounded-3xl border border-emerald-200 bg-emerald-50/40 p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="font-semibold text-slate-900">Yeu cau hoa hong</p>
                <p class="mt-1 text-sm text-slate-500"><%= formatDateTime(entry.date) %></p>
                <p class="mt-1 text-sm text-slate-500"><%= entry.description || "Khong co mo ta" %></p>
              </div>
              <div class="text-right">
                <p class="text-lg font-black text-emerald-700"><%= formatCurrency(entry.amount) %></p>
                <span class="mt-2 inline-flex rounded-full px-4 py-2 text-sm font-semibold <%= entry.approved ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' %>">
                  <%= entry.approved ? "Da duyet" : "Cho admin duyet" %>
                </span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
