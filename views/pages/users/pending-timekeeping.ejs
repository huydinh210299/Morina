<section class="space-y-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-3xl font-black text-slate-900">Duyệt chấm công</h1>
      <p class="mt-1 text-slate-500">Các bản ghi chấm công chưa duyệt của nhân viên.</p>
    </div>
    <div class="flex gap-3">
      <form method="GET" action="/users/timekeeping/pending" class="flex items-center gap-3">
        <input name="month" type="month" value="<%= selectedMonth %>" class="rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
        <button type="submit" class="rounded-full bg-slate-900 px-5 py-3 font-semibold text-white transition hover:bg-slate-700">Xem tháng</button>
      </form>
      <a href="/users" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700">Quay lại</a>
    </div>
  </div>

  <div class="space-y-4">
    <% if (pendingEntries.length === 0) { %>
      <div class="rounded-[2rem] bg-white p-8 text-slate-500 shadow-xl shadow-slate-200/60">Không có chấm công chờ duyệt trong tháng này.</div>
    <% } %>
    <% pendingEntries.forEach((entry) => { %>
      <div class="rounded-[2rem] bg-white p-6 shadow-xl shadow-slate-200/60">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <p class="text-lg font-black text-slate-900"><%= entry.username %></p>
            <p class="mt-1 text-slate-600"><%= entry.shiftName %> - <%= entry.hour %> giờ</p>
            <p class="mt-1 text-sm text-slate-500"><%= formatDateTime(entry.date) %></p>
            <p class="mt-1 text-sm text-slate-500"><%= entry.shiftDescription || "Không có mô tả" %></p>
          </div>
          <div class="flex flex-wrap gap-3">
            <form action="/users/<%= entry.userId %>/timekeeping/<%= entry.timekeepingId %>/approve" method="POST">
              <button type="submit" class="rounded-full bg-emerald-600 px-5 py-3 font-semibold text-white transition hover:bg-emerald-700">Duyệt chấm công</button>
            </form>
            <form action="/users/<%= entry.userId %>/timekeeping/<%= entry.timekeepingId %>?_method=DELETE" method="POST" onsubmit="return confirm('Xóa chấm công chờ duyệt này?');">
              <button type="submit" class="rounded-full bg-rose-100 px-5 py-3 font-semibold text-rose-700 transition hover:bg-rose-200">Xóa chấm công</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</section>
