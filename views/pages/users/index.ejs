<section class="space-y-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-3xl font-black text-slate-900">Quản lý</h1>
      <p class="mt-1 text-slate-500">Quản lý tài khoản, ca làm, chấm công, lương nhân viên và tiền mặt.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/users/new" class="inline-flex rounded-full bg-brand-500 px-5 py-3 font-semibold text-white transition hover:bg-brand-700">Thêm người dùng</a>
      <a href="/users/shifts" class="inline-flex rounded-full bg-slate-900 px-5 py-3 font-semibold text-white transition hover:bg-slate-700">Quản lý ca làm</a>
      <a href="/users/timekeeping/pending" class="inline-flex rounded-full bg-amber-100 px-5 py-3 font-semibold text-amber-800">Duyệt chấm công</a>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <div class="rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Nhân viên</p>
      <p class="mt-3 text-3xl font-black text-slate-900"><%= users.length %></p>
    </div>
    <div class="rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Chờ duyệt</p>
      <p class="mt-3 text-3xl font-black text-amber-700"><%= pendingCount %></p>
    </div>
    <div class="rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Lương theo giờ</p>
      <p class="mt-3 text-3xl font-black text-emerald-700"><%= formatCurrency(hourSalary) %></p>
    </div>
    <div class="rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Hoa hồng / đơn</p>
      <p class="mt-3 text-3xl font-black text-brand-700"><%= formatCurrency(commission) %></p>
    </div>

    <div class="rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60 md:col-span-2">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(320px,420px)] xl:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Tiền mặt</p>
          <p class="mt-3 text-3xl font-black text-slate-900"><%= formatCurrency(cashOnHand) %></p>
          <p class="mt-2 text-slate-500">Số dư tiền mặt hiện được lưu trong cấu hình hệ thống.</p>
        </div>
        <form action="/users/settings/cash-on-hand" method="POST" class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Cập nhật số dư tiền mặt</span>
            <input name="value" type="number" min="0" step="0.01" required value="<%= cashOnHand %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
          </label>
          <button type="submit" class="whitespace-nowrap rounded-full bg-brand-500 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Cập nhật tiền mặt</button>
        </form>
      </div>
    </div>

    <div class="rounded-3xl bg-white p-6 shadow-lg shadow-slate-200/60 md:col-span-2">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(320px,420px)] xl:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Hoa hồng theo đơn</p>
          <p class="mt-3 text-3xl font-black text-slate-900"><%= formatCurrency(commission) %></p>
          <p class="mt-2 text-slate-500">Mỗi đơn hàng nhân viên tạo trong tháng sẽ được cộng hoa hồng theo mức này.</p>
        </div>
        <form action="/users/settings/commission" method="POST" class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Cập nhật hoa hồng / đơn</span>
            <input name="value" type="number" min="0" step="1" required value="<%= commission %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
          </label>
          <button type="submit" class="whitespace-nowrap rounded-full bg-brand-500 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Cập nhật hoa hồng</button>
        </form>
      </div>
    </div>
  </div>

  <div class="table-scroll rounded-3xl bg-white shadow-lg shadow-slate-200/60">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Tài khoản</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Vai trò</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Tổng đơn</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Cập nhật</th>
          <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Thao tác</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% users.forEach((userItem) => { %>
          <tr>
            <td class="px-6 py-4">
              <div class="font-semibold text-slate-900"><%= userItem.username %></div>
            </td>
            <td class="px-6 py-4 text-slate-600"><%= userItem.role %></td>
            <td class="px-6 py-4 font-semibold text-slate-900"><%= userItem.totalOrder || 0 %></td>
            <td class="px-6 py-4 text-slate-600"><%= formatDateTime(userItem.updatedAt) %></td>
            <td class="px-6 py-4">
              <div class="flex justify-end gap-2">
                <a href="/users/<%= userItem._id %>" class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700">Xem</a>
                <a href="/users/<%= userItem._id %>/edit" class="rounded-full bg-amber-100 px-4 py-2 text-sm font-semibold text-amber-800">Sửa</a>
                <a href="/users/<%= userItem._id %>/payroll" class="rounded-full bg-emerald-100 px-4 py-2 text-sm font-semibold text-emerald-800">Lương tháng</a>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
