<section class="space-y-6">
  <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-700">Chi tiết người dùng</p>
        <h1 class="mt-3 text-3xl font-black text-slate-900"><%= userItem.username %></h1>
        <p class="mt-2 text-slate-500"><%= userItem.role %></p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/users/<%= userItem._id %>/payroll" class="rounded-full bg-emerald-100 px-5 py-3 font-semibold text-emerald-800">Lương tháng</a>
        <a href="/users/<%= userItem._id %>/edit" class="rounded-full bg-amber-100 px-5 py-3 font-semibold text-amber-800">Sửa</a>
        <a href="/users" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700">Quay lại</a>
      </div>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Thông tin tài khoản</p>
        <p class="mt-3 text-slate-700">Tên đăng nhập: <span class="font-semibold text-slate-900"><%= userItem.username %></span></p>
        <p class="mt-2 text-slate-700">Vai trò: <span class="font-semibold text-slate-900"><%= userItem.role %></span></p>
        <p class="mt-2 text-slate-700">Tổng đơn đã tạo: <span class="font-semibold text-slate-900"><%= userItem.totalOrder || 0 %></span></p>
        <p class="mt-2 text-slate-700">Số lần đã nhận lương: <span class="font-semibold text-slate-900"><%= userItem.salary?.length || 0 %></span></p>
      </div>

      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Lịch sử cập nhật</p>
        <p class="mt-3 text-slate-700">Tạo bởi: <span class="font-semibold text-slate-900"><%= userItem.createdBy %></span></p>
        <p class="mt-2 text-slate-700">Cập nhật bởi: <span class="font-semibold text-slate-900"><%= userItem.updatedBy %></span></p>
        <p class="mt-2 text-slate-700">Ngày tạo: <span class="font-semibold text-slate-900"><%= formatDateTime(userItem.createdAt) %></span></p>
        <p class="mt-2 text-slate-700">Lần cập nhật cuối: <span class="font-semibold text-slate-900"><%= formatDateTime(userItem.updatedAt) %></span></p>
      </div>
    </div>
  </div>
</section>
