<section class="mx-auto max-w-3xl space-y-6"><div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60"><h1 class="text-3xl font-black text-slate-900"><%= title %></h1><form action="<%= formAction %>" method="<%= formMethod %>" class="mt-8 space-y-5"><div><label for="title" class="mb-2 block text-sm font-semibold text-slate-700">Tiêu đề</label><input id="title" name="title" type="text" required value="<%= note?.title || '' %>" placeholder="Nhập tiêu đề ghi chú" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" /></div><div><label for="description" class="mb-2 block text-sm font-semibold text-slate-700">Nội dung</label><textarea id="description" name="description" rows="6" required placeholder="Nhập nội dung ghi chú" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"><%= note?.description || '' %></textarea></div><div><label for="categoryId" class="mb-2 block text-sm font-semibold text-slate-700">Danh mục ghi chú</label><select id="categoryId" name="categoryId" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"><option value="">Chọn danh mục ghi chú</option><% categories.forEach((category) => { %><option value="<%= category._id %>" <%= note?.categoryId?.toString() === category._id.toString() ? "selected" : "" %>><%= category.categoryCode %> - <%= category.displayName %></option><% }) %></select></div><div class="flex gap-3"><button type="submit" class="rounded-full bg-brand-500 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Lưu</button><a href="/notes" class="rounded-full bg-slate-100 px-6 py-3 font-semibold text-slate-700">Hủy</a></div></form></div></section>
