<%
  const buildPageUrl = (page) => {
    const params = new URLSearchParams();
    if (filters.keyword) params.set("keyword", filters.keyword);
    if (filters.categoryId) params.set("categoryId", filters.categoryId);
    params.set("page", page);
    return `/notes?${params.toString()}`;
  };
%>
<section class="min-w-0 space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"><div><h1 class="text-3xl font-black text-slate-900">Ghi chú</h1><p class="mt-1 text-slate-500">Theo dõi các ghi chú cho cửa hàng, nhân viên và đồ thuê.</p></div><% if (currentUser.role === "admin") { %><a href="/notes/new" class="inline-flex rounded-full bg-brand-500 px-5 py-3 font-semibold text-white transition hover:bg-brand-700">Thêm ghi chú</a><% } %></div>
  <form action="/notes" method="GET" class="grid gap-4 rounded-3xl bg-white p-5 shadow-lg shadow-slate-200/60 md:grid-cols-[1fr_16rem_auto]"><input name="keyword" value="<%= filters.keyword %>" placeholder="Tìm kiếm theo tiêu đề hoặc nội dung" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" /><select name="categoryId" class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"><option value="">Tất cả danh mục</option><% categories.forEach((category) => { %><option value="<%= category._id %>" <%= filters.categoryId === category._id.toString() ? "selected" : "" %>><%= category.categoryCode %> - <%= category.displayName %></option><% }) %></select><button type="submit" class="rounded-full bg-slate-900 px-6 py-3 font-semibold text-white">Tìm kiếm</button></form>
  <div class="min-w-0 overflow-hidden rounded-3xl bg-white shadow-lg shadow-slate-200/60"><div class="table-scroll"><table class="min-w-full divide-y divide-slate-200"><thead class="bg-slate-50"><tr><th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Tiêu đề</th><th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Nội dung</th><th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Danh mục</th><th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Thao tác</th></tr></thead><tbody class="divide-y divide-slate-100"><% if (notes.length === 0) { %><tr><td colspan="4" class="px-6 py-10 text-center text-slate-500">Không có dữ liệu.</td></tr><% } %><% notes.forEach((note) => { %><tr><td class="px-6 py-4 font-semibold text-slate-900"><%= note.title %></td><td class="table-cell-wrap px-6 py-4 text-slate-600"><%= note.description %></td><td class="px-6 py-4 text-slate-600"><%= note.categoryId?.categoryCode %> - <%= note.categoryId?.displayName %></td><td class="px-6 py-4"><div class="flex justify-end gap-2"><% if (currentUser.role === "admin") { %><a href="/notes/<%= note._id %>/edit" class="rounded-full bg-amber-100 px-4 py-2 text-sm font-semibold text-amber-800">Chỉnh sửa</a><form action="/notes/<%= note._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Xóa ghi chú này?');"><button type="submit" class="rounded-full bg-rose-100 px-4 py-2 text-sm font-semibold text-rose-800">Xóa</button></form><% } %></div></td></tr><% }) %></tbody></table></div></div>
  <div class="flex flex-col gap-3 rounded-3xl bg-white px-6 py-4 text-sm text-slate-600 shadow-lg shadow-slate-200/60 sm:flex-row sm:items-center sm:justify-between"><span>Trang <%= pagination.page %>/<%= pagination.totalPages %> · Tổng <%= pagination.totalItems %> ghi chú</span><div class="flex gap-2"><% if (pagination.hasPrev) { %><a href="<%= buildPageUrl(pagination.prevPage) %>" class="rounded-full bg-slate-100 px-4 py-2 font-semibold text-slate-700">Trang trước</a><% } %><% if (pagination.hasNext) { %><a href="<%= buildPageUrl(pagination.nextPage) %>" class="rounded-full bg-brand-50 px-4 py-2 font-semibold text-brand-700">Trang sau</a><% } %></div></div>
</section>
