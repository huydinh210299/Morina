<%
  const totalPaid = order.payments.reduce((sum, payment) => sum + Number(payment.amount || 0), 0);
  const totalDue = Number(order.orderAmount || 0) + Number(order.deposit || 0);
  const remainingAmount = totalDue - totalPaid;
  const isOverpaid = remainingAmount < 0;
%>

<section class="space-y-6">
  <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-700">Chi tiết đơn hàng</p>
        <h1 class="mt-3 text-3xl font-black text-slate-900"><%= order.customerName %> · <%= order.phone %></h1>
      </div>
      <div class="flex gap-3">
        <% if (currentUser.role === "admin") { %>
          <a href="/orders/<%= order._id %>/edit" class="rounded-full bg-amber-100 px-5 py-3 font-semibold text-amber-800">Sửa</a>
        <% } %>
        <a href="/orders" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700">Quay lại</a>
      </div>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Lịch thuê</p>
        <p class="mt-3 text-slate-700">Bắt đầu: <%= new Date(order.generalStartTime).toLocaleString() %></p>
        <p class="mt-2 text-slate-700">Kết thúc: <%= new Date(order.generalEndTime).toLocaleString() %></p>
      </div>
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Tài chính</p>
        <p class="mt-3 text-slate-700">Tổng tiền đơn: <%= formatCurrency(order.orderAmount) %></p>
        <p class="mt-2 text-slate-700">Tiền cọc: <%= formatCurrency(order.deposit) %></p>
        <p class="mt-2 text-slate-700">Phụ thu: <%= formatCurrency(order.surcharge) %></p>
        <p class="mt-2 text-slate-700">Tổng cần thu (đơn + cọc): <span class="font-semibold"><%= formatCurrency(totalDue) %></span></p>
        <p class="mt-2 text-slate-700">Đã thanh toán: <span class="font-semibold"><%= formatCurrency(totalPaid) %></span></p>
        <p class="mt-2 text-slate-700">
          <%= isOverpaid ? "Thanh toán dư" : "Còn cần thanh toán" %>:
          <span class="font-semibold <%= isOverpaid ? 'text-emerald-700' : 'text-rose-700' %>"><%= formatCurrency(Math.abs(remainingAmount)) %></span>
        </p>
      </div>
    </div>

    <form action="/orders/<%= order._id %>/note" method="POST" class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-5">
      <label class="mb-2 block text-sm font-semibold text-slate-700">Ghi chú đơn hàng</label>
      <textarea name="note" rows="4" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"><%= order.note || '' %></textarea>
      <button type="submit" class="mt-3 rounded-full bg-slate-900 px-5 py-3 font-semibold text-white transition hover:bg-slate-700">Cập nhật ghi chú</button>
    </form>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
      <h2 class="text-2xl font-black text-slate-900">Sản phẩm</h2>
      <div class="mt-5 space-y-4">
        <% if (order.products.length === 0) { %>
          <p class="text-slate-500">Chưa có dòng sản phẩm.</p>
        <% } %>
        <% order.products.forEach((item) => { %>
          <div class="rounded-3xl border border-slate-200 p-4">
            <p class="font-semibold text-slate-900"><%= item.product?.code || "Sản phẩm không xác định" %></p>
            <p class="mt-2 text-sm text-slate-600"><%= formatCurrency(item.price) %></p>
            <p class="mt-1 text-sm text-slate-500"><%= new Date(item.startTime).toLocaleString() %> → <%= new Date(item.endTime).toLocaleString() %></p>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
      <h2 class="text-2xl font-black text-slate-900">Phụ kiện</h2>
      <div class="mt-5 space-y-4">
        <% if (order.accessories.length === 0) { %>
          <p class="text-slate-500">Chưa có dòng phụ kiện.</p>
        <% } %>
        <% order.accessories.forEach((item) => { %>
          <div class="rounded-3xl border border-slate-200 p-4">
            <p class="font-semibold text-slate-900"><%= item.accessory?.code || "Phụ kiện không xác định" %> <%= item.accessory?.name ? `- ${item.accessory.name}` : "" %></p>
            <p class="mt-2 text-sm text-slate-600">Số lượng thuê: <%= item.amount ?? 1 %></p>
            <p class="mt-2 text-sm text-slate-600"><%= formatCurrency(item.price) %></p>
            <p class="mt-1 text-sm text-slate-500"><%= new Date(item.startTime).toLocaleString() %> → <%= new Date(item.endTime).toLocaleString() %></p>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
    <h2 class="text-2xl font-black text-slate-900">Thanh toán và trạng thái</h2>
    <div class="mt-5 grid gap-6 md:grid-cols-2">
      <div class="space-y-4">
        <form action="/orders/<%= order._id %>/payments" method="POST" class="rounded-3xl border border-brand-100 bg-brand-50/60 p-5">
          <h3 class="text-lg font-bold text-slate-900">Thêm thanh toán mới</h3>
          <% if (order.payments.length === 0) { %>
            <p class="mt-4 text-sm text-slate-500">Chưa có thanh toán nào.</p>
          <% } else { %>
            <div class="mt-4 space-y-3">
              <% order.payments.forEach((payment) => { %>
                <div class="rounded-3xl border border-brand-100 bg-white/80 p-4">
                  <p class="font-semibold text-slate-900"><%= formatCurrency(payment.amount) %></p>
                  <p class="mt-1 text-sm text-slate-500"><%= payment.type === 0 ? "Chuyển khoản" : "Tiền mặt" %></p>
                </div>
              <% }) %>
            </div>
          <% } %>

          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            <input name="amount" type="number" min="0" step="0.01" required placeholder="Số tiền" class="rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
            <select name="type" required class="rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100">
              <option value="0" selected>Chuyển khoản</option>
              <option value="1">Tiền mặt</option>
            </select>
          </div>
          <button type="submit" class="mt-4 rounded-full bg-brand-500 px-5 py-3 font-semibold text-white transition hover:bg-brand-700">Thêm thanh toán</button>
        </form>
      </div>

      <div class="space-y-4">
        <div class="rounded-3xl bg-slate-50 p-5">
          <p class="text-slate-700">Trạng thái lấy đồ: <span class="font-semibold"><%= order.alreadyPickup ? "Đã lấy" : "Chờ lấy" %></span></p>
          <p class="mt-3 text-slate-700">Trạng thái trả đồ: <span class="font-semibold"><%= order.returned ? "Đã trả" : "Đang thuê" %></span></p>
          <p class="mt-3 text-slate-700">Đã hoàn cọc: <span class="font-semibold"><%= order.returnDeposit ? "Có" : "Không" %></span></p>
        </div>

        <form action="/orders/<%= order._id %>/status" method="POST" class="rounded-3xl border border-slate-200 p-5">
          <h3 class="text-lg font-bold text-slate-900">Cập nhật trạng thái</h3>
          <div class="mt-4 space-y-3">
            <label class="flex items-center gap-3 text-sm font-semibold text-slate-700">
              <input name="alreadyPickup" type="checkbox" <%= order.alreadyPickup ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
              Đã lấy đồ
            </label>
            <label class="flex items-center gap-3 text-sm font-semibold text-slate-700">
              <input name="returned" type="checkbox" <%= order.returned ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
              Đã trả đồ
            </label>
            <label class="flex items-center gap-3 text-sm font-semibold text-slate-700">
              <input name="returnDeposit" type="checkbox" <%= order.returnDeposit ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
              Đã hoàn cọc
            </label>
          </div>
          <button type="submit" class="mt-4 rounded-full bg-slate-900 px-5 py-3 font-semibold text-white transition hover:bg-slate-700">Cập nhật trạng thái</button>
        </form>
      </div>
    </div>
  </div>
</section>
