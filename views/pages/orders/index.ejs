<%
  const currentFilters = filters || {};
  const currentPagination = pagination || {};
  const queryParams = new URLSearchParams();

  if (currentFilters.phone) queryParams.set("phone", currentFilters.phone);
  if (currentFilters.rentStartDate) queryParams.set("rentStartDate", currentFilters.rentStartDate);
  if (currentFilters.rentEndDate) queryParams.set("rentEndDate", currentFilters.rentEndDate);
  if (currentFilters.todayOrders) queryParams.set("todayOrders", "on");
  if (currentFilters.tomorrowOrders) queryParams.set("tomorrowOrders", "on");
  if (currentFilters.returnDueToday) queryParams.set("returnDueToday", "on");
  if (currentFilters.overdueUnreturned) queryParams.set("overdueUnreturned", "on");
  if (currentFilters.returnedNotRefunded) queryParams.set("returnedNotRefunded", "on");
  if (currentFilters.important) queryParams.set("important", "on");
  if (currentFilters.excludeCompletedImportant) queryParams.set("excludeCompletedImportant", "on");
  if (currentFilters.bookship && currentFilters.bookship !== "all") queryParams.set("bookship", currentFilters.bookship);
  if (currentFilters.returned && currentFilters.returned !== "all") queryParams.set("returned", currentFilters.returned);
  if (currentFilters.refund && currentFilters.refund !== "all") queryParams.set("refund", currentFilters.refund);
  if (currentFilters.pickup && currentFilters.pickup !== "all") queryParams.set("pickup", currentFilters.pickup);

  const buildPageUrl = (page) => {
    const params = new URLSearchParams(queryParams.toString());
    params.set("page", page);
    return `/orders?${params.toString()}`;
  };
%>

<section class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-black text-slate-900">Đơn hàng</h1>
      <p class="mt-1 text-slate-500">Theo dõi lịch thuê, thông tin liên hệ, ngày tạo đơn và trạng thái giao trả.</p>
    </div>
    <a href="/orders/new" class="inline-flex rounded-full bg-brand-500 px-5 py-3 font-semibold text-white transition hover:bg-brand-700">Tạo đơn hàng</a>
  </div>

  <form action="/orders" method="GET" class="rounded-3xl bg-white p-5 shadow-lg shadow-slate-200/60">
    <div class="grid gap-4 xl:grid-cols-[1.2fr_1fr_1fr_auto]">
      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">Số điện thoại</span>
        <input
          name="phone"
          type="text"
          value="<%= currentFilters.phone || '' %>"
          placeholder="Tìm theo số điện thoại"
          class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
        />
      </label>

      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">Ngày thuê từ</span>
        <input
          name="rentStartDate"
          type="date"
          min="<%= monthBounds.min %>"
          max="<%= monthBounds.max %>"
          value="<%= currentFilters.rentStartDate %>"
          class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
        />
      </label>

      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">Ngày thuê đến</span>
        <input
          name="rentEndDate"
          type="date"
          min="<%= monthBounds.min %>"
          max="<%= monthBounds.max %>"
          value="<%= currentFilters.rentEndDate %>"
          class="w-full rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
        />
      </label>

      <div class="flex flex-wrap items-end gap-3">
        <button type="submit" class="rounded-full bg-brand-500 px-5 py-3 font-semibold text-white transition hover:bg-brand-700">Lọc</button>
        <a href="/orders" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700 transition hover:bg-slate-200">Đặt lại</a>
      </div>
    </div>

    <div class="mt-4 grid gap-4 rounded-2xl bg-slate-50 px-4 py-3 sm:grid-cols-2 xl:grid-cols-4">
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="bookship" value="true" type="checkbox" <%= currentFilters.bookship === "true" ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Đặt giao hàng
      </label>
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="returned" value="false" type="checkbox" <%= currentFilters.returned === "false" ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Chưa trả hàng
      </label>
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="refund" value="false" type="checkbox" <%= currentFilters.refund === "false" ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Chưa hoàn tiền
      </label>
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="pickup" value="false" type="checkbox" <%= currentFilters.pickup === "false" ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Chưa lấy hàng
      </label>

      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="todayOrders" type="checkbox" <%= currentFilters.todayOrders ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Đơn hôm nay
      </label>

      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="tomorrowOrders" type="checkbox" <%= currentFilters.tomorrowOrders ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Đơn ngày mai
      </label>
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="returnDueToday" type="checkbox" <%= currentFilters.returnDueToday ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Cần trả hôm nay, chưa trả
      </label>
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="overdueUnreturned" type="checkbox" <%= currentFilters.overdueUnreturned ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Quá hạn, chưa trả
      </label>
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="returnedNotRefunded" type="checkbox" <%= currentFilters.returnedNotRefunded ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Đã trả hàng, chưa hoàn cọc
      </label>
      <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700">
        <input name="important" type="checkbox" <%= currentFilters.important ? "checked" : "" %> class="size-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
        Đơn quan trọng
      </label>
    </div>
  </form>

  <div class="overflow-hidden rounded-3xl bg-white shadow-lg shadow-slate-200/60">
    <div class="table-scroll">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Khách hàng</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Mã sản phẩm</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Ngày thuê</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Ngày tạo</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Số tiền</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Trạng thái</th>
            <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-[0.25em] text-slate-500">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="7" class="px-6 py-10 text-center text-slate-500">Không có đơn hàng phù hợp với bộ lọc hiện tại.</td>
            </tr>
          <% } %>

          <% orders.forEach((order) => { %>
            <tr>
              <td class="px-6 py-4 text-slate-600">
                <span class="mr-2 inline-flex rounded-full bg-fuchsia-100 px-3 py-1 text-xs font-semibold text-fuchsia-800"><%= order.bookship ? "Có giao hàng" : "Không giao hàng" %></span>
                <% if (order.important) { %>
                  <span class="mr-2 inline-flex rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-800">Quan trọng</span>
                <% } %>
                <%= order.customerName %><br />
                <span class="text-xs text-slate-400"><%= order.phone %></span>
              </td>
              <td class="px-6 py-4 text-slate-600">
                <% const productCodes = order.products.map((item) => item.product?.code).filter(Boolean); %>
                <% if (productCodes.length) { %>
                  <div class="flex flex-wrap gap-2">
                    <% productCodes.forEach((code) => { %>
                      <span class="inline-flex rounded-full bg-violet-100 px-3 py-1 text-xs font-semibold text-violet-800"><%= code %></span>
                    <% }) %>
                  </div>
                <% } else { %>
                  <span class="text-slate-400">—</span>
                <% } %>
              </td>
              <td class="px-6 py-4 text-slate-600">
                <%= new Date(order.generalStartTime).toLocaleString() %><br />
                <%= new Date(order.generalEndTime).toLocaleString() %>
              </td>
              <td class="px-6 py-4 text-slate-600"><%= new Date(order.createdAt).toLocaleString() %></td>
              <td class="px-6 py-4 text-slate-600">
                <%= formatCurrency(order.orderAmount) %><br />
                <span class="text-xs text-slate-400">Cọc: <%= formatCurrency(order.deposit || 0) %></span>
              </td>
              <td class="px-6 py-4 text-slate-600">
                <span class="mr-2 inline-flex rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-800"><%= order.alreadyPickup ? "Đã lấy" : "Chờ lấy" %></span>
                <span class="mr-2 inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800"><%= order.returned ? "Đã trả" : "Đang thuê" %></span>
                <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800"><%= order.returnDeposit ? "Đã hoàn cọc" : "Chưa hoàn cọc" %></span>
              </td>
              <td class="px-6 py-4">
                <div class="flex justify-end gap-2">
                  <a href="/orders/<%= order._id %>" class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700">Xem</a>
                  <% if (currentUser.role === "admin") { %>
                    <a href="/orders/<%= order._id %>/edit" class="rounded-full bg-amber-100 px-4 py-2 text-sm font-semibold text-amber-800">Sửa</a>
                    <form action="/orders/<%= order._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Xóa đơn hàng này?');">
                      <button type="submit" class="rounded-full bg-rose-100 px-4 py-2 text-sm font-semibold text-rose-800">Xóa</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="flex flex-col gap-4 border-t border-slate-200 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-slate-500">
        Trang <span class="font-semibold text-slate-700"><%= currentPagination.page %></span> / <span class="font-semibold text-slate-700"><%= currentPagination.totalPages %></span>
        - Tổng <span class="font-semibold text-slate-700"><%= currentPagination.totalItems %></span> đơn hàng
      </p>

      <div class="flex items-center gap-3">
        <% if (currentPagination.hasPrev) { %>
          <a href="<%= buildPageUrl(currentPagination.prevPage) %>" class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200">Trang trước</a>
        <% } else { %>
          <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-400">Trang trước</span>
        <% } %>

        <% if (currentPagination.hasNext) { %>
          <a href="<%= buildPageUrl(currentPagination.nextPage) %>" class="rounded-full bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700 transition hover:bg-brand-100">Trang sau</a>
        <% } else { %>
          <span class="rounded-full bg-brand-50 px-4 py-2 text-sm font-semibold text-slate-400">Trang sau</span>
        <% } %>
      </div>
    </div>
  </div>
</section>
