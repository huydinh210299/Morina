<section class="space-y-6">
  <%- include("../../partials/product-management-tabs", { activeProductManagementTab: "products" }) %>
  <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-700">Chi tiết sản phẩm</p>
        <h1 class="mt-3 text-3xl font-black text-slate-900"><%= product.code %></h1>
        <p class="mt-2 text-slate-500">
          <%= product.category?.code || "-" %>
          <% if (product.size) { %>
            · Size <%= product.size %>
          <% } %>
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/products/<%= product._id %>/schedule" class="rounded-full bg-brand-100 px-5 py-3 font-semibold text-brand-800">Lịch thuê</a>
        <% if (currentUser.role === "admin") { %>
          <a href="/products/<%= product._id %>/edit" class="rounded-full bg-amber-100 px-5 py-3 font-semibold text-amber-800">Sửa</a>
        <% } %>
        <a href="/products" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700">Quay lại</a>
      </div>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Mã sản phẩm</p>
        <p class="mt-3 text-xl font-bold text-slate-900"><%= product.code %></p>
      </div>
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Danh mục</p>
        <p class="mt-3 text-xl font-bold text-slate-900"><%= product.category?.code || "-" %></p>
      </div>
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Giá cả ngày</p>
        <p class="mt-3 text-xl font-bold text-slate-900"><%= formatCurrency(product.fullDayPrice) %></p>
      </div>
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Giá 8 giờ</p>
        <p class="mt-3 text-xl font-bold text-slate-900"><%= formatCurrency(product.eightHPrice) %></p>
      </div>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
    <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
      <h2 class="text-2xl font-black text-slate-900">Thông tin thêm</h2>
      <dl class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="rounded-3xl border border-slate-200 p-5">
          <dt class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Kích cỡ</dt>
          <dd class="mt-3 text-lg font-semibold text-slate-900"><%= product.size || "-" %></dd>
        </div>
        <div class="rounded-3xl border border-slate-200 p-5">
          <dt class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Ngày tạo</dt>
          <dd class="mt-3 text-lg font-semibold text-slate-900"><%= formatDateTime(product.createdAt) %></dd>
        </div>
        <div class="rounded-3xl border border-slate-200 p-5 md:col-span-2">
          <dt class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Ghi chú</dt>
          <dd class="mt-3 text-slate-700"><%= product.note || "Không có ghi chú." %></dd>
        </div>
      </dl>
    </div>

    <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
      <h2 class="text-2xl font-black text-slate-900">Tác vụ nhanh</h2>
      <div class="mt-6 space-y-4">
        <a href="/products/<%= product._id %>/schedule" class="block rounded-3xl border border-brand-200 bg-brand-50/70 p-5 transition hover:border-brand-300 hover:bg-brand-50">
          <p class="text-lg font-bold text-slate-900">Xem lịch thuê</p>
          <p class="mt-2 text-sm text-slate-600">Mở danh sách các mốc đang thuê và sắp thuê của sản phẩm này.</p>
        </a>
        <% if (currentUser.role === "admin") { %>
          <a href="/products/<%= product._id %>/edit" class="block rounded-3xl border border-amber-200 bg-amber-50/70 p-5 transition hover:border-amber-300 hover:bg-amber-50">
            <p class="text-lg font-bold text-slate-900">Cập nhật sản phẩm</p>
            <p class="mt-2 text-sm text-slate-600">Sửa giá thuê, kích cỡ, danh mục hoặc ghi chú.</p>
          </a>
        <% } %>
      </div>
    </div>
  </div>
</section>
