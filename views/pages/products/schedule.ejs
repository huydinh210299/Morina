<section class="space-y-6">
  <%- include("../../partials/product-management-tabs", { activeProductManagementTab: "products" }) %>
  <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-700">Lịch thuê sản phẩm</p>
        <h1 class="mt-3 text-3xl font-black text-slate-900"><%= product.code %></h1>
        <p class="mt-2 text-slate-500">
          <%= product.category?.code || "-" %>
          <% if (product.size) { %>
            · Size <%= product.size %>
          <% } %>
        </p>
      </div>
      <div class="flex gap-3">
        <a href="/products/<%= product._id %>" class="rounded-full bg-brand-100 px-5 py-3 font-semibold text-brand-800">Xem sản phẩm</a>
        <% if (currentUser.role === "admin") { %>
          <a href="/products/<%= product._id %>/edit" class="rounded-full bg-amber-100 px-5 py-3 font-semibold text-amber-800">Sửa</a>
        <% } %>
        <a href="/products" class="rounded-full bg-slate-100 px-5 py-3 font-semibold text-slate-700">Quay lại</a>
      </div>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Giá thuê</p>
        <p class="mt-3 text-slate-700">Cả ngày: <span class="font-semibold"><%= formatCurrency(product.fullDayPrice) %></span></p>
        <p class="mt-2 text-slate-700">8 giờ: <span class="font-semibold"><%= formatCurrency(product.eightHPrice) %></span></p>
      </div>
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Trạng thái lịch</p>
        <p class="mt-3 text-slate-700">Đang được thuê lúc này: <span class="font-semibold"><%= currentRentCount %></span></p>
        <p class="mt-2 text-slate-700">Sắp bắt đầu: <span class="font-semibold"><%= upcomingRentCount %></span></p>
        <p class="mt-2 text-slate-700">Tổng mốc lịch chưa trả: <span class="font-semibold"><%= rentSchedule.length %></span></p>
      </div>
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-500">Ghi chú</p>
        <p class="mt-3 text-slate-700"><%= product.note || "Không có ghi chú." %></p>
      </div>
    </div>
  </div>

  <div class="rounded-[2rem] bg-white p-8 shadow-xl shadow-slate-200/60">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-2xl font-black text-slate-900">Lịch thuê</h2>
        <p class="mt-1 text-slate-500">Lấy thời gian từ từng dòng sản phẩm trong đơn hàng và bỏ qua đơn đã trả.</p>
      </div>
    </div>

    <% if (rentSchedule.length === 0) { %>
      <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center text-slate-500">
        Sản phẩm này hiện chưa có lịch thuê nào đang mở.
      </div>
    <% } else { %>
      <div class="mt-6 space-y-4">
        <% rentSchedule.forEach((item, index) => { %>
          <div class="rounded-3xl border border-slate-200 p-5">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-3">
                  <a href="/orders/<%= item.orderId %>" class="text-lg font-bold text-slate-900 transition hover:text-brand-700">Xem đơn hàng</a>
                  <% if (new Date(item.startTime) <= new Date() && new Date(item.endTime) >= new Date()) { %>
                    <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800">Đang trong lịch thuê</span>
                  <% } else if (new Date(item.startTime) > new Date()) { %>
                    <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">Sắp bắt đầu</span>
                  <% } %>
                </div>
                <p class="mt-2 text-slate-600"><%= item.customerName %> · <%= item.phone %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-600">
                <p>Bắt đầu: <span class="font-semibold text-slate-900"><%= formatDateTime(item.startTime) %></span></p>
                <p class="mt-1">Kết thúc: <span class="font-semibold text-slate-900"><%= formatDateTime(item.endTime) %></span></p>
              </div>
            </div>

            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <div class="rounded-2xl bg-brand-50/60 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-700">Khung thuê của sản phẩm</p>
                <p class="mt-2 text-slate-700"><%= formatDateTime(item.startTime) %> -> <%= formatDateTime(item.endTime) %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Khung tổng của đơn</p>
                <p class="mt-2 text-slate-700"><%= formatDateTime(item.generalStartTime) %> -> <%= formatDateTime(item.generalEndTime) %></p>
              </div>
            </div>

            <% if (index < rentSchedule.length - 1) { %>
              <div class="mt-4 border-t border-dashed border-slate-200 pt-4 text-sm text-slate-400">
                Mốc lịch tiếp theo sau khung này.
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
